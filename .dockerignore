storage/framework/sessions/*
storage/framework/views/*
storage/app/*
!storage/app/.gitignore
!storage/framework/.gitignore
!storage/logs/.gitignore

# Build artifacts
public/build
public/hot

# Host-built FrankenPHP binary (base image provides the correct arch)
/frankenphp

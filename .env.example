# ---------------------------------------------------------------------------
# PulseBoard Environment Configuration
# Copy to .env and customize for your environment.
# ---------------------------------------------------------------------------

# ---- Application -----------------------------------------------------------
APP_NAME=PulseBoard
APP_ENV=local                    # local, production, staging
APP_KEY=                         # Auto-generated: php artisan key:generate
APP_DEBUG=true                   # MUST be false in production
APP_URL=http://localhost:8000    # Full URL including port if non-standard

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# ---- Security --------------------------------------------------------------
BCRYPT_ROUNDS=12                 # Increase for stronger hashing (slower)

# ---- Server (Octane / FrankenPHP) ------------------------------------------
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false               # Set true if terminating TLS at the app
OCTANE_WORKERS=4                 # Number of Octane worker processes

# ---- Database ---------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1                # Use "mysql" when running in Docker
DB_PORT=3306
DB_DATABASE=pulseboard
DB_USERNAME=pulseboard
DB_PASSWORD=secret               # CHANGE in production

# Docker MySQL root password (only used by docker-compose)
# DB_ROOT_PASSWORD=secret

# ---- Redis ------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1             # Use "redis" when running in Docker
REDIS_PASSWORD=null               # Set a password in production
REDIS_PORT=6379

# ---- Session ----------------------------------------------------------------
SESSION_DRIVER=redis             # redis recommended for production
SESSION_LIFETIME=120             # Minutes
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null              # Set to your domain in production (e.g. .example.com)
SESSION_SECURE_COOKIE=false      # Set true when using HTTPS
SESSION_SAME_SITE=lax            # lax, strict, or none

# ---- Cache & Queue ----------------------------------------------------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# ---- Logging ----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single                 # Use "daily" in production for log rotation
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                  # Use "info" or "warning" in production

# ---- Mail -------------------------------------------------------------------
MAIL_MAILER=log                  # Use "smtp" in production
MAIL_SCHEME=null                 # "tls" for port 587, "ssl" for port 465
MAIL_HOST=127.0.0.1
MAIL_PORT=2525                   # 587 for TLS, 465 for SSL
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@pulseboard.local"
MAIL_FROM_NAME="${APP_NAME}"

# ---- WebSocket (Laravel Reverb) --------------------------------------------
REVERB_APP_ID=pulseboard            # REQUIRED — Reverb exits if null
REVERB_APP_KEY=pulseboard-key       # Generate a random key for production
REVERB_APP_SECRET=pulseboard-secret # Generate a random secret for production
REVERB_HOST=localhost               # Public hostname clients connect to (e.g. ws.board.example.com)
REVERB_PORT=443                     # Client-facing port (443 behind TLS proxy, 8080 for local dev)
REVERB_SCHEME=https                 # Use "http" for local development without TLS

# ---- Vite (Frontend Build) -------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# ---- Trusted Proxies -------------------------------------------------------
# Set if behind a reverse proxy or load balancer (comma-separated IPs, or *)
# TRUSTED_PROXIES=*

# ---- Docker Compose Overrides ----------------------------------------------
# These are only used by docker-compose.prod.yml
# APP_PORT=8000                  # Host port for the web server
# REVERB_EXTERNAL_PORT=9080      # Host port for WebSocket
# PULSEBOARD_IMAGE=ghcr.io/dowilcox/pulseboard:latest  # Docker image name:tag

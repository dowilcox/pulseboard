#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

prettier_files=()
php_files=()

while IFS= read -r -d '' file; do
    [[ -f "$file" ]] || continue

    case "$file" in
        *.php)
            php_files+=("$file")
            ;;
        *)
            prettier_files+=("$file")
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if (( ${#prettier_files[@]} == 0 && ${#php_files[@]} == 0 )); then
    exit 0
fi

if (( ${#prettier_files[@]} > 0 )); then
    if ! command -v prettier >/dev/null 2>&1; then
        echo "pre-commit: prettier is not installed." >&2
        echo "Install it globally with: npm install -g prettier" >&2
        exit 1
    fi

    echo "pre-commit: formatting staged files with prettier"
    prettier --write --ignore-unknown "${prettier_files[@]}"
    git add -- "${prettier_files[@]}"
fi

if (( ${#php_files[@]} > 0 )); then
    if [[ ! -x ./vendor/bin/pint ]]; then
        echo "pre-commit: vendor/bin/pint is missing." >&2
        echo "Run composer install to make Pint available." >&2
        exit 1
    fi

    echo "pre-commit: formatting staged PHP files with Pint"
    ./vendor/bin/pint --quiet "${php_files[@]}"
    git add -- "${php_files[@]}"
fi
